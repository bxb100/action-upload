{
  "name": "upload-action",
  "version": "0.2.0",
  "private": true,
  "description": "Uniform Uploader Github Action",
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "format:write": "oxfmt --write '**/*.ts'",
    "format:check": "oxfmt --check '**/*.ts'",
    "lint": "oxlint src/**/*.ts",
    "local-action": "NODE_OPTIONS=--no-experimental-strip-types NODE_ENV=test npx @github/local-action . src/main.ts .env",
    "download": "./script/download_binary.sh",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "package": "rimraf dist && npm run build && npm run download",
    "all": "npm run build && npm run format:write && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bxb100/action-upload.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "Lemon",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/glob": "^0.6.1",
    "opendal": "^0.49.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.3.0",
    "eslint-plugin-github": "^6.0.0",
    "jest": "^30.2.0",
    "js-yaml": "^4.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.1",
    "typescript": "^5.4.3"
  }
}
